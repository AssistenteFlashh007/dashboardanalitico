# ===== META ADS =====
# Acesse developers.facebook.com > Criar App > Marketing API
# Token: Tools > Access Token Tool > Gerar com permissão ads_read
META_ACCESS_TOKEN=seu_token_aqui
META_AD_ACCOUNT_ID=act_XXXXXXXXX
META_APP_ID=seu_app_id
META_APP_SECRET=seu_app_secret

# ===== HUBLA =====
# Acesse app.hub.la > Integrações > API > Copiar token
HUBLA_API_TOKEN=seu_token_hubla

# ===== PAGTRUST =====
# Acesse ead.pagtrust.com.br > Integrações > Webhooks > Token
PAGTRUST_WEBHOOK_TOKEN=seu_token_pagtrust

# ===== SERVIDOR =====
PORT=3001
